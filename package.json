{
  "name": "x402-seller-testkit",
  "version": "0.1.0",
  "description": "Seller-side x402 conformance and regression harness.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bortlesboat/x402-seller-testkit.git"
  },
  "bugs": {
    "url": "https://github.com/Bortlesboat/x402-seller-testkit/issues"
  },
  "homepage": "https://github.com/Bortlesboat/x402-seller-testkit#readme",
  "bin": {
    "x402-testkit": "./dist/cli/run.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm typecheck && pnpm lint:check && pnpm format:check && pnpm test",
    "format": "prettier --write \"**/*.{ts,json,md,yml,mjs}\"",
    "lint": "eslint . --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example:local": "tsx examples/local-express/main.ts",
    "lint:check": "eslint . --ext .ts",
    "format:check": "prettier --check \"**/*.{ts,json,md,yml,mjs}\""
  },
  "keywords": [
    "x402",
    "bitcoin",
    "payments",
    "conformance",
    "harness",
    "seller"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "dependencies": {
    "@x402/core": "^2.9.0",
    "@x402/express": "^2.9.0",
    "@x402/fetch": "^2.9.0",
    "express": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.13.4",
    "@types/express": "^5.0.1",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.24.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.9",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=22"
  }
}
